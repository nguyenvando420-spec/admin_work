PROJECT_NAME="Admin Auth System"
API_V1_STR="/api/v1"

# Security
SECRET_KEY="replace_this_with_a_very_secret_random_string_in_production"
ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=11520 # 8 days

# Database
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgrespassword
POSTGRES_DB=admin_db
SQLALCHEMY_DATABASE_URI="postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@localhost:5432/${POSTGRES_DB}"

# First Superuser
FIRST_SUPERUSER_USERNAME="admin"
FIRST_SUPERUSER_PASSWORD="Admin@123"
FIRST_SUPERUSER_EMAIL="admin@example.com"
